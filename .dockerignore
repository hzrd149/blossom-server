# Runtime data — never bake into image; mounted as a named volume
data/

# Config — mounted at runtime via docker-compose.yml volume
config.yml

# Legacy Node.js implementation — not used by the Deno server
legacy-nodejs/

# Tests — not needed at runtime
tests/

# Git submodule (BUD spec reference) — read-only docs, not needed at runtime
blossom/

# Session files
.sessions/

# Dev environment
.env
.github/
.vscode/

# Top-level node_modules (none should exist, but guard against accidental copy)
/node_modules/

# Frontend build outputs — built inside the Docker builder stage, not copied in
# from the host. Excluding these keeps the build context lean and ensures the
# image always contains a clean build.
admin/dist/
admin/node_modules/
landing/dist/
landing/node_modules/

# public/ — static assets served differently; admin/landing serve their own dist
public/

# Scripts not needed in the image (clean.ts uses Deno.remove which modifies host)
# Keep scripts/ included — it's small and deno task clean is harmless in container
