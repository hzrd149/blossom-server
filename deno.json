{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"]
  },
  "exclude": ["tests/stress/"],
  "tasks": {
    "dev": "deno run --env-file=.env --watch --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-sys --allow-run main.ts",
    "start": "deno run --env-file=.env --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-sys --allow-run main.ts",
    "test": "deno test --env-file=.env --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-sys tests/unit/ tests/e2e/",
    "build-landing": "deno run --allow-all npm:vite build --config vite.config.landing.ts",
    "build": "deno task build-landing",
    "clean": "deno run --env-file=.env --allow-read --allow-write scripts/clean.ts"
  },
  "imports": {
    "@bradenmacdonald/s3-lite-client": "jsr:@bradenmacdonald/s3-lite-client@^0.9.5",
    "@hono/hono": "jsr:@hono/hono@^4.12.7",
    "@libsql/client": "npm:@libsql/client@^0.17.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/media-types": "jsr:@std/media-types@^1.1.0",
    "@std/crypto": "jsr:@std/crypto@^1.0.5",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/log": "jsr:@std/log@^0.224.14",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/ulid": "jsr:@std/ulid@^1.0.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "nostr-tools": "npm:nostr-tools@^2.23.3",
    "sharp": "npm:sharp@^0.34.5",
    "file-type": "npm:file-type@^19.6.0",
    "vite": "npm:vite@^8.0.0",
    "zod": "npm:zod@^4.3.6",
    "hono/jsx/dom": "jsr:@hono/hono@^4.12.7/jsx/dom",
    "hono/jsx/dom/jsx-runtime": "jsr:@hono/hono@^4.12.7/jsx/dom/jsx-runtime",
    "hono/jsx/jsx-runtime": "jsr:@hono/hono@^4.12.7/jsx/jsx-runtime",
    "@hono/hono/basic-auth": "jsr:@hono/hono@^4.12.7/basic-auth"
  },
  "allowScripts": ["npm:esbuild@0.21.5", "npm:sharp@0.34.5"]
}
